# Copy this file to `.env` (gitignored) and use real values.
# All VITE_* vars are exposed to the browser — never put secrets here.

# Backend API base URL
VITE_API_BASE_URL=https://cp-inventory-portal.onrender.com/api

# Cloudinary (public — safe to expose)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=cp_unit_photos
