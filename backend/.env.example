# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must never be committed.

# Main app database (our tables: cities, CPs, societies, submissions, faqs)
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/openhouse-cp-portal?sslmode=require

# Properties database (read-only — for duplicate checks and tower/unit auto-fills)
# Added in Step 3
# PROPERTIES_DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/properties?sslmode=require

# JWT secret (for phone-login tokens — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
# Added in Step 3
# JWT_SECRET=

# Frontend origin for CORS (set after frontend is deployed)
# Added in Step 3
# FRONTEND_ORIGIN=http://localhost:5173
