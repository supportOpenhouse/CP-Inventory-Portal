# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# ---- Required ----

# Main app database (cities, CPs, societies, submissions, faqs)
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/openhouse-cp-portal?sslmode=require

# JWT secret for auth tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-48-char-random-string

# ---- Optional (for now) ----

# Properties database (read-only — for duplicate checks and tower/unit auto-fills)
# Leave blank in Step 3; /health will report "not configured" gracefully.
PROPERTIES_DATABASE_URL=

# Frontend origin for CORS. Set to your React dev server or deployed URL.
FRONTEND_ORIGIN=http://localhost:5173

# Flask environment: development or production
FLASK_ENV=development
